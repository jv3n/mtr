# Copy to .env (git-ignored). NEVER commit a real key.
# In GCP production: these values come from Secret Manager, not a file.

TRADEZERO_API_KEY=
TRADEZERO_API_SECRET=
# "paper" (default, mandatory at the start) or "live".
TRADEZERO_ENV=paper

# Market data provider: Massive (formerly Polygon.io). Separate from TradeZero,
# which has no market data. Legacy name POLYGON_API_KEY is still accepted.
MASSIVE_API_KEY=
# Free/Basic tier = 15-min delayed / EOD (no real-time). Use the delayed WS host
# for dev; leave unset for the real-time host (paid Stocks plan required).
# MASSIVE_WS_URL=wss://delayed.massive.com/stocks

# Alerts (optional): set both to push kill-switch / disconnect / shutdown alerts to
# Telegram. Leave empty to log-only.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Scheduled window (optional): the bot flattens + stops at SESSION_END in SESSION_TZ.
# Used by the GCP scheduled deployment; leave unset for local dev (runs until killed).
# SESSION_END=16:00
# SESSION_TZ=America/New_York

# Entry cutoff: no NEW position after this time. DIFFERENT from SESSION_END, which is
# when the book gets flattened — late-session pushes tend not to come back down (#16).
# Always a New York rule; ENTRY_TZ only exists to be overridden in tests.
# ENTRY_CUTOFF=15:00
# ENTRY_TZ=America/New_York

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space

[*.{kt,kts}]
indent_size = 4
ktlint_code_style = ktlint_official
# Long docstrings/comments are common here; don't fail the build on line length.
max_line_length = off
ktlint_standard_max-line-length = disabled
